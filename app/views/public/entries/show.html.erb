<% reading_minutes = @entry.start_time && @entry.end_time ? ((@entry.end_time - @entry.start_time) / 60).round : 0 %>
<% share_text = "Just read for #{reading_minutes} minute#{'s' if reading_minutes != 1} and earned #{@entry.crumbs} crumb#{'s' if @entry.crumbs != 1} on Breadshelf! 📚🍞" %>
<% twitter_url = "https://twitter.com/intent/tweet?text=#{CGI.escape(share_text)}" %>

<div class="entry-show"
     data-controller="crumbs"
     data-crumbs-total-value="<%= @entry.crumbs %>"
     data-crumbs-reading-value="<%= @reading_crumbs %>"
     data-crumbs-note-value="<%= @note_crumbs %>"
     data-crumbs-particle-src-value="<%= asset_path('crumbs.svg') %>">

  <h1 class="entry-show__title"><%= @entry.user_book.book.title.titlecase %></h1>

  <div class="entry-show__reward">
    <span class="entry-show__crumb-number" data-crumbs-target="count">0</span>
    <span class="entry-show__crumb-label">crumbs earned</span>
  </div>

  <div class="entry-show__breakdown" data-crumbs-target="breakdown" hidden>
    <p class="entry-show__breakdown-item">
      <span data-crumbs-target="readingCount">0</span> from reading
    </p>
    <p class="entry-show__breakdown-item">
      <span data-crumbs-target="noteCount">0</span> from your note
    </p>
  </div>

  <div class="entry-show__share" data-crumbs-target="share" hidden>
    <%= link_to 'Share on Twitter', twitter_url,
          target: '_blank', rel: 'noopener noreferrer',
          class: 'button' %>
    <button class="button button--ghost"
            data-action="crumbs#share"
            data-crumbs-share-text-param="<%= share_text %>">
      Share / Copy
    </button>
  </div>
</div>
