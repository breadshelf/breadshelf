<div>
    <h1>What are you reading?</h1>
        
    <%= simple_form_for(:book, url: user_books_path, method: :post, local: true) do |f| %>
        <div data-controller="user-books" class="user-books form-group">
            <div class="input-wrapper">
                <%= f.input :title, 
                    label: false,
                    placeholder: 'Book title',
                    required: true,
                    input_html: { data: { turbo: true } } %>
            </div>
            <div class="input-wrapper">
                <%= f.input :author, 
                    label: false,
                    placeholder: 'Author name (optional)',
                    required: false,
                    input_html: { data: { turbo: true } } %>
            </div>
            <%= f.submit 'Next', class: 'button' %>
        </div>
    <% end %>
    <% # TODO: BUTTON THAT ALLOWS USERS TO GO BACK TO LAST BOOK %>
</div>