<div>
    <h1>What are you reading?</h1>
        
    <%= simple_form_for(:entry, url: entries_path, method: :post, local: true) do |f| %>
        <div data-controller="user-books" class="user-books form-group">
            <div class="input-wrapper">
                <%= f.input :book_title, 
                    label: false,
                    placeholder: 'Book title',
                    required: true,
                    input_html: { data: { turbo: true } } %>
                <button type="button" 
                        class="toggle-arrow" 
                        data-action="user-books#toggle"
                        data-user-books-target="toggleButton"
                        aria-label="Show author field">
                    ▼
                </button>
            </div>
            <div data-user-books-target="authorField" hidden>
                <div class="input-wrapper">
                <%= f.input :author_name, 
                    label: false,
                    placeholder: 'Author name (optional)',
                    required: false,
                    input_html: { data: { turbo: true } } %>
                </div>
            </div>  
            <%= f.submit 'Next', class: 'button' %>
        </div>
    <% end %>
    <% # TODO: BUTTON THAT ALLOWS USERS TO GO BACK TO LAST BOOK %>
</div>