<div class="note-container">
  <h1 class="note__book-title"><%= @note.entry.book.title.titlecase %></h1>
  <% if @note.entry.book.author.present? %>
    <p class="note__author">by <%= @note.entry.book.author.titlecase %></p>
  <% end %>

  <% if @note.content.present? %>
    <div class="note__content">
      <%= @note.content %>
    </div>
  <% end %>

  <button class="button note__start-reading" disabled>Start reading</button>
</div>
