<div class="note-container">
  <h1 class="note__book-title"><%= @note.entry.user_book.book.title.titlecase %></h1>
  <% if @note.entry.user_book.book.author.present? %>
<p class="note__author">by <%= @note.entry.user_book.book.author.titlecase %></p>
  <% end %>

  <% if @note.content.present? %>
    <div class="note__content">
      <%= @note.content %>
    </div>
  <% end %>

  <%= link_to 'Start reading', begin_entry_path(user_book_id: @note.entry.user_book.id), class: 'button note__start-reading', data: { turbo_method: :post } %>
</div>
